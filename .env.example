# ─── WhatsApp Business API (Meta) ───────────────────────────
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_access_token
WA_VERIFY_TOKEN=your_verify_token

# ─── SAP B1 Service Layer ────────────────────────────────────
SAP_SERVICE_LAYER_URL=https://your-sap-server:50000/b1s/v2/
SAP_COMPANY_DB=YourCompanyDB
SAP_DATABASES=DB1;DB2
SAP_USERNAME=manager
SAP_PASSWORD=your_password

# ─── Claude AI API ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Uygulama ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Onay Yetkilileri ─────────────────────────────────────────
APPROVER_PHONES=905xxxxxxxxx,905yyyyyyyyy

# ─── Yönetim Paneli ───────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_SESSION_SECRET=random_secret_string
