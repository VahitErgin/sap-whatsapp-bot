# ─── WhatsApp Business API (Meta) ───────────────────────────
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=EAAxxxx...
WA_VERIFY_TOKEN=sawbot-webhook-2024

# ─── SAP B1 Service Layer ────────────────────────────────────
SAP_SERVICE_LAYER_URL=https://SAP-SUNUCU:50000/b1s/v2/
SAP_COMPANY_DB=YourCompanyDB
SAP_DATABASES=DB1;DB2          # birden fazla varsa noktalı virgülle, boş olabilir
SAP_USERNAME=manager
SAP_PASSWORD=your_sap_password

# ─── SAP B1 Direkt SQL ───────────────────────────────────────
# SAP_DB_TYPE: mssql (varsayılan) veya hana
# SAP_DB_PORT: MSSQL için 1433 (varsayılan), HANA için 30015
SAP_DB_TYPE=mssql
SAP_DB_SERVER=192.168.1.10
SAP_DB_PORT=1433
SAP_DB_NAME=YourCompanyDB
SAP_DB_USER=sa
SAP_DB_PASSWORD=your_sql_password

# ─── Claude AI API (Anthropic) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── OpenAI Whisper (Sesli mesaj — isteğe bağlı) ─────────────
OPENAI_API_KEY=sk-proj-...

# ─── Uygulama ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Onay Yetkilileri ─────────────────────────────────────────
# Satın alma onaylarını WhatsApp'tan yapacak kişilerin numaraları
APPROVER_PHONES=905001112233,905004445566

# ─── Servis Bildirimleri ──────────────────────────────────────
# Meta Business Manager'da onaylı WhatsApp template adı
SERVIS_NOTIF_TEMPLATE=servis_durum_guncelleme

# ─── Yönetim Paneli ───────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_SESSION_SECRET=random_32_char_secret_string_here

# ─── Microsoft Graph / Outlook Takvim ────────────────────────
# Azure Portal → App registrations → yeni uygulama
# Gerekli uygulama izni: Calendars.ReadWrite (Application)
GRAPH_ENABLED=false
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER_DOMAIN=@company.com

# ─── Stok Ayarları ───────────────────────────────────────────
# SAP B1'de varsayılan fiyat listesi numarası (ITM1.PriceList)
STOCK_PRICE_LIST=1

# ─── Kullanıcı Lisansı ────────────────────────────────────────
# Bota erişebilecek maksimum WhatsApp kullanıcı sayısı.
# Boş bırakılırsa kısıtlama yoktur (geliştirme / iç kullanım).
MAX_USERS=20

# ─── CRM / Oturum Ayarları ────────────────────────────────────
SESSION_TIMEOUT_MINUTES=480
CRM_ACTIVE_TYPES=Phone Call,Meeting,Task,Note,Email
CRM_ACTIVE_SUBJECTS=
ATTACHMENT_MAX_MB=5
